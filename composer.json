{
    "name": "oshco/adfs",
    "description": "Library to provide ADFS integration for WebFiori based applications.",
    "require": {
        "webfiori/http":"5.0.*",
        "webfiori/file":"2.0.*",
        "webfiori/jsonx":"4.0.*",
        "webfiori/ui":"4.0.*"
    },
    "keywords": [
        "ADFS",
        "webfiori",
        "API",
        "Web APIs"
    ],
    "license": "MIT",
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Oshco\\": "Oshco/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
